PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sleep_and_journey

# Omise (https://dashboard.omise.co/keys) - use test keys (pkey_test_/skey_test_) while developing
OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxx
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxx

# 2C2P (https://portal.2c2p.com) - secret key used to verify backend notification signatures
TWOCTWOP_MERCHANT_ID=JT01
TWOCTWOP_SECRET_KEY=change_me
TWOCTWOP_API_BASE=https://sandbox-pgw.2c2p.com
TWOCTWOP_FRONTEND_RETURN_URL=https://your-frontend.example.com/payment/return
TWOCTWOP_BACKEND_RETURN_URL=https://your-api.example.com/v1/webhooks/payment/2c2p

# Auth
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
